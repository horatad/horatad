  "lagna_rules": {
    "_source": "ch013 — ลัคนา ตนุเศษ ตนุลัคน์",
    "lakkana": {
      "name": "ลัคนา",
      "description": "จุดเริ่มต้นการนับเรือน — คำนวณจากระบบสุริยยาตร์ (06:00 ตายตัว เวลาท้องถิ่น)",
      "engine_note": "planet_id=0 ไม่ใช่ดาว — คือจุดลัคนา"
    },
    "tanusesh": {
      "name": "ตนุเศษ",
      "description": "นิสัย/อารมณ์พื้นฐาน — คำนวณจากวันเกิดและรอบเวลาเกิด",
      "formula": "(birth_day × birth_period) % 7",
      "formula_note": "birth_day=วันที่ 1-31, birth_period=เลขรอบเวลา (1-8 แล้วแต่ระบบ), เศษ 0 นับเป็น 7",
      "result_range": "1–7 → planet_id 1=อาทิตย์ ... 7=เสาร์",
      "not_applicable_planet_ids": [
        0,
        8,
        9
      ],
      "not_applicable_note": "มฤตยู(0)/ราหู(8)/เกตุ(9) ไม่เป็นตนุเศษได้ (สูตร %7 ให้ผล 1-7 เท่านั้น)",
      "notation": "× = เป็นหลัก (dominant), + = มีส่วน (contributing)",
      "per_planet_trait": "ดู tals_planets.json → field tanusesh_trait"
    },
    "tanulagn": {
      "name": "ตนุลัคน์",
      "description": "ตัวตนภายในแท้ สันดาน — เจ้าเรือนลัคนา",
      "rule": "ruler_of_sign(lagna_sign)",
      "lookup": "ดู tals_signs.json → ruler field ของ sign ที่เป็นลัคนา",
      "expression_modifier": "สัมพันธ์ลัคนา (กุม/เล็ง/โยค/ตรีโกณ) → แสดงออกชัด | ไม่สัมพันธ์ → ซ่อนอยู่ภายใน (อัจฉริยภาพภายใน)",
      "not_applicable_planet_ids": [],
      "not_applicable_note": "ราหู(8) เป็นตนุลัคน์ได้ (กุมภ์ลัคนา) — verified ch013",
      "per_planet_inner": "ดู tals_planets.json → field tanulagn_inner"
    },
    "three_layer_identity": {
      "name": "3 ชั้นตัวตน",
      "layers": [
        {
          "layer": 1,
          "name": "ตนุเศษ",
          "aspect": "นิสัย/อารมณ์",
          "method": "คำนวณ formula"
        },
        {
          "layer": 2,
          "name": "ตนุลัคน์",
          "aspect": "ตัวตนภายใน/สันดาน",
          "method": "ruler ของ lagna sign"
        },
        {
          "layer": 3,
          "name": "ดาวสัมพันธ์ลัคนา",
          "aspect": "การแสดงออกภายนอก",
          "method": "aspect to lagna"
        }
      ],
      "note": "ทั้ง 3 ชั้น อาจขัดกันได้ — ตีความรวมกัน ไม่ใช้ชั้นเดียว"
    }
  },
  "ruen_nok_nai_rule": {
    "_source": "ch011+ch016+ch021",
    "definitions": {
      "ruen_nok": {
        "name_th": "ดาวเคราะห์เรือนนอก",
        "alt_name": "ดาวลอย",
        "description": "ดาว 10 ดวงที่เขียนลงในแผ่นดวงชาตา — มีคุณภาพตามตำแหน่งจริงในชาร์ต",
        "quality": "ตามที่คำนวณได้จริง (อุจ/เกษตร/มหาจักร/นิจ/ฯลฯ)",
        "engine_note": "ใช้ quality จาก quality_maps.json ตามราศีที่ดาวสถิต"
      },
      "ruen_nai": {
        "name_th": "ดาวเคราะห์เรือนใน",
        "alt_name": "ดาวเจ้าเรือน / เกษตรเรือนใน",
        "description": "เจ้าเรือน (ruler) ของราศีแต่ละราศี — มีอยู่เสมอ ซ่อนอยู่หลังฉาก",
        "quality": "เกษตร เสมอ (strength_pct=80) ในราศีของตัวเอง",
        "engine_note": "lookup: tals_signs.json → ruler field"
      }
    },
    "scoring_rule": {
      "rule": "ทุกภพมีทั้ง เรือนนอก (ดาวลอย ถ้ามี) + เรือนใน (เจ้าเรือน เสมอ) — ต้องพิจารณาทั้งคู่",
      "ruen_nai_base_strength": 80,
      "ruen_nai_quality_fixed": "เกษตร",
      "ruen_nok_strength": "ตามคุณภาพจริง (อุจ=100, เกษตร=80, ประเกษตร=-80, นิจ=-100)",
      "combination_method": "ดู เรือนใน + เรือนนอก แยกกัน แล้วนำมาประมวลรวม",
      "special_case_kum_lagna": "ถ้าเรือนนอก กุมลัคนา → aspect_weight 100% → เสริมหรือลดคุณสมบัติลัคนา"
    },
    "engine_implementation_note": "prediction engine ต้องคำนวณทั้ง เรือนนอก + เรือนใน ของทุกภพ ไม่ใช่แค่ดาวลอย"
  }
