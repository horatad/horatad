flowchart TD
    START([LLM output JSON])
    Q1{Parse JSON valid?}
    Q2{all rule_id ∈ KB?}
    Q3{transit have valid<br/>anchor_natal_id?}
    Q4{Western vocab<br/>detected?}
    ACCEPT([✅ accept])
    RETRY1[❌ retry: parse fail]
    RETRY2["❌ retry: 'R999 invalid'"]
    RETRY3["❌ retry: 'missing anchor'"]
    RETRY4["❌ retry: 'use Thai vocab only'"]

    START --> Q1
    Q1 -- no --> RETRY1
    Q1 -- yes --> Q2
    Q2 -- no --> RETRY2
    Q2 -- yes --> Q3
    Q3 -- no --> RETRY3
    Q3 -- yes --> Q4
    Q4 -- yes --> RETRY4
    Q4 -- no --> ACCEPT

    style ACCEPT fill:#d4edda,stroke:#155724,stroke-width:3px
    style RETRY1 fill:#f8d7da
    style RETRY2 fill:#f8d7da
    style RETRY3 fill:#f8d7da
    style RETRY4 fill:#f8d7da
